-- Get{{table_name $.Table.Name "one"}}{{query_index $key}} retrieves a single row from '{{$.Table.Name}}' by {{$key.Name}}.
-- Returns the row or an error if not found.
-- name: {{$query_name}} :one
SELECT
    *
FROM
    {{$.Table.Name}}
WHERE
