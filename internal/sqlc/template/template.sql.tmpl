{{- end}}
{{- if eq $key $.Table.PrimaryKey}}
{{- range $fk := $.Table.ForeignKeys}}
{{- $query_name := printf "Get%s%sWith%s" (table_name $.Table.Name "one") (query_index $key) (table_name (table_ref $fk) "one")}}
