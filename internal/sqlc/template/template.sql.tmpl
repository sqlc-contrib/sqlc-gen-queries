-- The result is a struct with both tables table_embedded.
-- name: {{$query_name}} :one
SELECT
    {{table_embed $.Table.Name}}, {{table_embed $fk.References.Table}}
FROM
    {{$.Table.Name}}
{{table_join $.Table $fk}}
WHERE
    {{query_condition $.Table $key}};
{{- end}}
{{- end}}
{{- end}}

